{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "upload-image-r2",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
  },
  "observability": {
    "enabled": true,
  },
  "compatibility_flags": ["nodejs_compat"],

