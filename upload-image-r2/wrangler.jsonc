   * Note: Use secrets to store sensitive data.
   * https://developers.cloudflare.com/workers/configuration/secrets/
   */
  "vars": {
    "R2_ACCESS_KEY": "fd8062757b3ee12134aee729ef45e933",
    "R2_SECRET_KEY": "72d16b2339f95b074f92642e4f5edf17da6833b4ffc2b7023570f3f3804ff982",
  },
